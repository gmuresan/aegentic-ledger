---
// EntryCard (Story 72.1, AC3) — archive/timeline list item. surface-raised card
// with a 3px left accent bar tinted by stream color (the at-a-glance stream
// signal). The record is textual — no images.
import StreamBadge from './StreamBadge.astro';

interface Props {
  title: string;
  date: string;
  stream: 'agent-ledger' | 'build-log';
  slug: string;
  // Story 75.5 (AC3): optional per-agent attribution. When present and non-empty, a small
  // agent chip renders beside the stream badge so readers see which agent authored the entry
  // at a glance. Absent (pre-75.5 entries) → no chip, never an error.
  agentSlug?: string;
}
const { title, date, stream, slug, agentSlug } = Astro.props;
const accent = stream === 'agent-ledger' ? 'var(--stream-agent)' : 'var(--stream-build)';
const displayDate = date.includes('T') ? date.slice(0, date.indexOf('T')) : date;
---

<a class="entry-card" href={`/ledger/${slug}/`} style={`--accent: ${accent}`}>
  <div class="meta">
    <StreamBadge stream={stream} />
    <span class="date">{displayDate}</span>
  </div>
  {agentSlug && <span class="agent-chip">{agentSlug}</span>}
  <h2 class="title">{title}</h2>
</a>

<style>
  .entry-card {
    display: block;
    position: relative;
    background: var(--surface-raised);
    border: 1px solid var(--hairline);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-md);
    padding: var(--stack);
    margin: var(--stack) 0;
    text-decoration: none;
  }

  .entry-card:hover {
    border-color: var(--hairline-strong);
    border-left-color: var(--accent);
    text-decoration: none;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: var(--gutter);
    margin-bottom: var(--stack-tight);
  }

  .date {
    font-family: var(--font-body);
    font-size: var(--body-sm-size);
    color: var(--ink-muted);
  }

  /* Per-agent attribution chip (75.5, AC3) — same scale as the date, muted, no decoration. */
  .agent-chip {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--body-sm-size);
    color: var(--ink-muted);
    margin-bottom: var(--stack-tight);
  }

  .title {
    font-family: var(--font-display);
    font-size: var(--headline-sm-size);
    font-weight: 500;
    color: var(--ink-primary);
    margin: 0;
  }
</style>
