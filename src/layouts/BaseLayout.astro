---
// BaseLayout (Story 72.1, AC3) — site-wide shell. Loads the Aegentic tokens and the
// three webfonts (no runtime JS), renders a minimal nav, the page slot, and the
// footer verify block.
//
// Fonts via Bunny Fonts (privacy-friendly Google Fonts mirror, no cookies) using
// the preconnect + stylesheet pattern — no JS required (AC3).
import '../styles/tokens.css';
import FooterVerifyBlock from '../components/FooterVerifyBlock.astro';

interface Props {
  title: string;
  description?: string;
  wallet?: string;
  explorerUrl?: string;
  explorerName?: string;
}
const {
  title,
  description = 'A live, verifiable build-in-public record of a self-custody DeFi yield agent.',
  wallet,
  explorerUrl,
  explorerName,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- RSS discovery (feed.xml generated by astro build from src/pages/feed.xml.ts) -->
    <link rel="alternate" type="application/rss+xml" title="Aegentic Ledger" href="/feed.xml" />

    <!-- Fonts: Newsreader (serif/display), Inter (body/UI), JetBrains Mono (on-chain data) -->
    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.bunny.net/css?family=newsreader:400,500|inter:400,600|jetbrains-mono:500,600&display=swap"
    />
  </head>
  <body>
    <nav class="site-nav">
      <a class="wordmark" href="/">Aegentic</a>
      <div class="links">
        <a href="/ledger">Ledger</a>
        <a href="/about">About</a>
        <a href="/waitlist">Waitlist</a>
        <a href="/feed.xml">RSS</a>
      </div>
    </nav>

    <main class="site-main">
      <slot />
    </main>

    <FooterVerifyBlock wallet={wallet} explorerUrl={explorerUrl} explorerName={explorerName} />

    <style>
      .site-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: var(--content-max);
        margin: 0 auto;
        padding: var(--stack) var(--margin-mobile);
        border-bottom: 1px solid var(--hairline);
      }

      .wordmark {
        font-family: var(--font-display);
        font-size: var(--headline-sm-size);
        font-weight: 500;
        color: var(--brand);
        text-decoration: none;
      }

      .links {
        display: flex;
        gap: var(--gutter);
      }

      .links a {
        font-family: var(--font-body);
        font-size: var(--label-caps-size);
        font-weight: var(--label-caps-weight);
        letter-spacing: var(--label-caps-ls);
        text-transform: uppercase;
        color: var(--ink-secondary);
        text-decoration: none;
      }

      .links a:hover {
        color: var(--ink-primary);
      }

      .site-main {
        max-width: var(--content-max);
        margin: 0 auto;
        padding: var(--stack) var(--margin-mobile) var(--section-gap-mobile);
      }

      /* ── Responsive shell (Story 72.3, AC5: breakpoints + mobile-nav) ── */
      /* Tablet: keep the nav on one row but let it wrap before clipping. */
      @media (max-width: 768px) {
        .site-nav {
          flex-wrap: wrap;
          gap: var(--stack);
        }
        .links {
          gap: var(--stack);
        }
      }

      /* Mobile: the nav links stack under the wordmark; tighter side padding so the
         reading column is full-width with breathing room. No JS — pure flex-wrap. */
      @media (max-width: 480px) {
        .site-nav {
          padding: var(--stack) 0.75rem;
        }
        .links {
          flex-basis: 100%;
          gap: 1rem;
        }
        .links a {
          font-size: var(--body-sm-size);
        }
        .site-main {
          padding: var(--stack) 0.75rem var(--section-gap-mobile);
        }
      }
    </style>
  </body>
</html>
