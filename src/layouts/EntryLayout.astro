---
// EntryLayout (Story 72.1, AC3) — per-entry shell. Uses BaseLayout, constrains the
// reading column to entry-max (760px), and ENFORCES the fixed layout order:
//
//   stream-badge + <h1> title + date meta
//   → above-fold callouts (slot "callouts")
//   → editorial prose (slot "prose")
//   → <details> "Receipts & reasoning" (Story 75.3) collapsing:
//       → <section class="fact-panel"> (slot "fact")
//       → receipts (slot "receipts")
//
// Story 75.3 demotes the evidence below the fold: the fact panel + receipts live
// inside a collapsed native <details>, and its <summary> "Receipts & reasoning" is
// now the visible facts↔commentary wall landmark (G1) — replacing the bare <hr>.
// The fact zone itself remains the labeled landmark, supplied via the FactPanel
// component in the "fact" slot (build-shape contract #6). The evidence is present
// and complete, just demoted — never removed. Structural and build-time; no client JS.
import BaseLayout from './BaseLayout.astro';
import StreamBadge from '../components/StreamBadge.astro';

interface Props {
  title: string;
  date: string;
  stream: 'agent-ledger' | 'build-log';
  wallet?: string;
  explorerUrl?: string;
  explorerName?: string;
}
const { title, date, stream, wallet, explorerUrl, explorerName } = Astro.props;
const displayDate = date.includes('T') ? date.slice(0, date.indexOf('T')) : date;
---

<BaseLayout
  title={title}
  wallet={wallet}
  explorerUrl={explorerUrl}
  explorerName={explorerName}
>
  <article class="entry">
    <header class="entry-head">
      <StreamBadge stream={stream} />
      <h1 class="entry-title">{title}</h1>
      <p class="entry-date mono">{displayDate}</p>
    </header>

    <div class="callouts">
      <slot name="callouts" />
    </div>

    {/* Story 75.7 (AC2) — forward-seam for entry-level screenshot attribution. The slot is
        wired but empty today ([slug].astro passes []) — :empty hides the zone so there is no
        blank space until a future story populates it. */}
    <div class="screenshot-zone">
      <slot name="screenshot" />
    </div>

    <div class="prose-zone">
      <slot name="prose" />
    </div>

    <details class="receipts-and-reasoning">
      <summary class="fact-wall-summary">Receipts &amp; reasoning</summary>

      <div class="fact-zone">
        <slot name="fact" />
      </div>

      <div class="receipts">
        <slot name="receipts" />
      </div>
    </details>
  </article>

  <style>
    .entry {
      max-width: var(--entry-max);
      margin: 0 auto;
    }

    .entry-head {
      display: flex;
      flex-direction: column;
      gap: var(--stack-tight);
      margin-bottom: var(--stack);
    }

    .entry-title {
      font-family: var(--font-display);
      font-size: var(--headline-size);
      font-weight: 500;
      line-height: 1.2;
      color: var(--ink-primary);
      margin: var(--stack-tight) 0 0;
    }

    .entry-date {
      font-family: var(--font-mono);
      font-size: var(--mono-data-size);
      color: var(--ink-muted);
      margin: 0;
    }

    /* Story 75.7: collapse the screenshot zone when its slot renders nothing (no blank gap). */
    .screenshot-zone:empty {
      display: none;
    }

    /* Editorial prose: capped at the reading measure, set in body sans. */
    .prose-zone {
      max-width: var(--reading-measure);
      font-family: var(--font-body);
      font-size: var(--body-lg-size);
      line-height: var(--body-lg-lh);
      color: var(--ink-primary);
    }

    .prose-zone :global(h2),
    .prose-zone :global(h3) {
      font-family: var(--font-display);
    }

    /* The facts↔commentary wall (G1): the <summary> is now the visible separator
       landmark — the editorial prose sits above it, the evidence one click below.
       The fact zone + receipts collapse into a native <details> (no client JS). */
    .receipts-and-reasoning {
      margin: var(--fact-wall-gap) 0 0;
    }

    .fact-wall-summary {
      font-family: var(--font-body);
      font-size: var(--label-caps-size);
      font-weight: var(--label-caps-weight);
      letter-spacing: var(--label-caps-ls);
      color: var(--ink-muted);
      cursor: pointer;
      border-top: 1px solid var(--hairline-strong);
      padding-top: var(--fact-wall-gap);
      list-style: none; /* hide default disclosure triangle */
    }

    .fact-wall-summary::marker,
    .fact-wall-summary::-webkit-details-marker {
      display: none;
    }

    .receipts {
      margin-top: var(--stack);
    }

    /* ── Responsive (Story 72.3, AC5) — reading column full-width on mobile. ── */
    @media (max-width: 480px) {
      .prose-zone {
        max-width: 100%;
      }
      .entry-title {
        font-size: var(--headline-sm-size);
      }
    }
  </style>
</BaseLayout>
